# PrepBuddy Environment Variables Template
# Copy this file to '.env' and fill in your custom API credentials.

# Google Gemini API key for Socratic coaching
GEMINI_API_KEY=YOUR_API_KEY

# Google Custom Search API credentials for course explorer
GOOGLE_API_KEY=YOUR_API_KEY
GOOGLE_CSE_ID=YOUR_CSE_ID

# FastAPI JWT secret key (for token signature verification)
SECRET_KEY=YOUR_SECRET_KEY
